function attachEvents(){
  document.getElementById('monthInput')?.addEventListener('change', e => {
    state.month = e.target.value || state.month;
    saveState();
    render();
  });

  document.getElementById('reloadBtn')?.addEventListener('click', async () => {
    await loadRemote();
    render();
  });

  autoCalc('issued');
  autoCalc('received');
  attachXmlImport('issued');
  attachXmlImport('received');

  document.getElementById('issuedForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const item = {
      id:uid(), date:fd.get('date') || hoy(), client:fd.get('client') || '', invoiceNumber:fd.get('invoiceNumber') || '',
      subtotal:num(fd.get('subtotal')), iva:num(fd.get('iva')), total:num(fd.get('total')), paid:fd.get('paid')==='on',
      paymentDate:fd.get('paymentDate') || '', notes:fd.get('xmlNotes') || ''
    };
    await addItem('issued',item);
  });

  document.getElementById('receivedForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const item = {
      id:uid(), date:fd.get('date') || hoy(), provider:fd.get('provider') || '', invoiceNumber:fd.get('invoiceNumber') || '',
      subtotal:num(fd.get('subtotal')), iva:num(fd.get('iva')), total:num(fd.get('total')), paid:fd.get('paid')==='on',
      paymentDate:fd.get('paymentDate') || '', notes:fd.get('xmlNotes') || ''
    };
    await addItem('received',item);
  });

  document.getElementById('serviceForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const item = {
      id:uid(), date:fd.get('date') || hoy(), client:fd.get('client') || '', serviceNumber:fd.get('serviceNumber') || '',
      equipment:fd.get('equipment') || '', work:fd.get('work') || '', amount:num(fd.get('amount')),
      invoiced:fd.get('invoiced')==='on', invoiceNumber:fd.get('invoiceNumber') || ''
    };
    await addItem('services',item);
  });

  document.getElementById('taxSettingsForm')?.addEventListener('submit', e => {
    e.preventDefault();
    const fd = new FormData(e.target);
    state.ivaRate = num(fd.get('ivaRate'));
    state.isrRate = num(fd.get('isrRate'));
    saveState();
    alert('Configuración guardada.');
    render();
  });

  document.getElementById('supabaseSettingsForm')?.addEventListener('submit', async e => {
    e.preventDefault();
    const fd = new FormData(e.target);
    state.supabaseUrl = String(fd.get('supabaseUrl') || '').trim();
    state.supabaseKey = String(fd.get('supabaseKey') || '').trim();
    saveState();
    connectSupabase();
    await loadRemote();
    render();
  });

  document.getElementById('testSupabaseBtn')?.addEventListener('click', async () => {
    connectSupabase();
    await loadRemote();
    render();
  });

  document.getElementById('clearLocalBtn')?.addEventListener('click', () => {
    if(confirm('¿Borrar datos locales de este navegador? No borra Supabase.')){
      localStorage.removeItem(STORAGE_KEY);
      state = {...seed};
      connectSupabase();
      render();
    }
  });

  document.getElementById('copySqlBtn')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(SUPABASE_SQL);
    alert('SQL copiado.');
  });

  document.querySelectorAll('[data-toggle-paid]').forEach(btn => {
    btn.onclick = async () => {
      const type = btn.dataset.togglePaid;
      const id = btn.dataset.id;
      const item = state[type].find(x => String(x.id) === String(id));
      if(!item) return;
      item.paid = !item.paid;
      item.paymentDate = item.paid ? (item.paymentDate || hoy()) : '';
      try{
        if(supabaseClient && !String(id).startsWith('local_')){
          await updateRemote(type,id,{paid:item.paid,paymentDate:item.paymentDate});
          await loadRemote();
        }
        saveState();
        render();
      }catch(err){
        console.error(err);
        alert('No pude actualizar.');
      }
    };
  });

  document.querySelectorAll('[data-toggle-service]').forEach(btn => {
    btn.onclick = async () => {
      const id = btn.dataset.toggleService;
      const item = state.services.find(x => String(x.id) === String(id));
      if(!item) return;
      item.invoiced = !item.invoiced;
      if(item.invoiced && !item.invoiceNumber){
        item.invoiceNumber = prompt('Número de factura relacionada, si aplica:', '') || '';
      }
      try{
        if(supabaseClient && !String(id).startsWith('local_')){
          await updateRemote('services',id,{invoiced:item.invoiced,invoiceNumber:item.invoiceNumber});
          await loadRemote();
        }
        saveState();
        render();
      }catch(err){
        console.error(err);
        alert('No pude actualizar.');
      }
    };
  });

  document.querySelectorAll('[data-delete]').forEach(btn => {
    btn.onclick = async () => {
      const type = btn.dataset.delete;
      const id = btn.dataset.id;
      if(!confirm('¿Borrar este registro?')) return;
      try{
        if(supabaseClient && !String(id).startsWith('local_')){
          await deleteRemote(type,id);
          await loadRemote();
        }else{
          state[type] = state[type].filter(x => String(x.id) !== String(id));
        }
        saveState();
        render();
      }catch(err){
        console.error(err);
        alert('No pude borrar.');
      }
    };
  });
}

function autoCalc(type){
  const sub = document.getElementById(type+'Subtotal');
  const iva = document.getElementById(type+'Iva');
  const total = document.getElementById(type+'Total');
  if(!sub || !iva || !total) return;

  function update(){
    const ivaCalc = calcIva(sub.value);
    iva.value = ivaCalc;
    total.value = calcTotal(sub.value, ivaCalc);
  }
  sub.addEventListener('input', update);
  iva.addEventListener('input', () => total.value = calcTotal(sub.value, iva.value));
}

async function addItem(type,item){
  try{
    if(supabaseClient){
      await insertRemote(type,item);
      await loadRemote();
    }else{
      state[type].unshift(item);
    }
    saveState();
    render();
  }catch(err){
    console.error(err);
    alert('No pude guardar. Si estás usando Supabase, revisa SQL, URL, key y permisos.');
  }
}

const SUPABASE_SQL = `-- SotoMed Control V1.1
-- Ejecuta esto en Supabase > SQL Editor.
-- Para esta V1 rápida se agregan políticas abiertas para anon.
-- Úsalo como arranque; después conviene meter login y políticas por usuario.

create table if not exists public.sotomed_issued_invoices (
  id bigint generated always as identity primary key,
  created_at timestamptz not null default now(),
  invoice_date date not null,
  client text,
  invoice_number text,
  subtotal numeric(12,2) not null default 0,
  iva numeric(12,2) not null default 0,
  total numeric(12,2) not null default 0,
  paid boolean not null default false,
  payment_date date,
  notes text
);

create table if not exists public.sotomed_received_invoices (
  id bigint generated always as identity primary key,
  created_at timestamptz not null default now(),
  invoice_date date not null,
  provider text,
  invoice_number text,
  subtotal numeric(12,2) not null default 0,
  iva numeric(12,2) not null default 0,
  total numeric(12,2) not null default 0,
  paid boolean not null default false,
  payment_date date,
  notes text
);

create table if not exists public.sotomed_service_sheets (
  id bigint generated always as identity primary key,
  created_at timestamptz not null default now(),
  service_date date not null,
  client text,
  service_number text,
  equipment text,
  work_done text,
  amount numeric(12,2) not null default 0,
  invoiced boolean not null default false,
  invoice_number text
);

alter table public.sotomed_issued_invoices enable row level security;
alter table public.sotomed_received_invoices enable row level security;
alter table public.sotomed_service_sheets enable row level security;

drop policy if exists "sotomed issued anon all" on public.sotomed_issued_invoices;
drop policy if exists "sotomed received anon all" on public.sotomed_received_invoices;
drop policy if exists "sotomed services anon all" on public.sotomed_service_sheets;

create policy "sotomed issued anon all"
on public.sotomed_issued_invoices
for all
to anon
using (true)
with check (true);

create policy "sotomed received anon all"
on public.sotomed_received_invoices
for all
to anon
using (true)
with check (true);

create policy "sotomed services anon all"
on public.sotomed_service_sheets
for all
to anon
using (true)
with check (true);

create index if not exists idx_sotomed_issued_invoice_date on public.sotomed_issued_invoices(invoice_date);
create index if not exists idx_sotomed_received_invoice_date on public.sotomed_received_invoices(invoice_date);
create index if not exists idx_sotomed_service_date on public.sotomed_service_sheets(service_date);`;

connectSupabase();
loadRemote().then(render);
</script>
