  return `
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Fecha</th><th>${nameCol}</th><th>Factura</th><th>Subtotal</th><th>IVA</th><th>Total</th><th>Estado</th>${compact?'':'<th>Acciones</th>'}
          </tr>
        </thead>
        <tbody>
          ${rows.map(r => `
            <tr>
              <td>${esc(r.date)}</td>
              <td>${esc(type==='issued'?r.client:r.provider)}</td>
              <td>${esc(r.invoiceNumber)}</td>
              <td>${money(r.subtotal)}</td>
              <td>${money(r.iva)}</td>
              <td><b>${money(r.total)}</b></td>
              <td>${r.paid ? '<span class="badge good">Pagada</span>' : '<span class="badge warn">Pendiente</span>'}</td>
              ${compact?'':`<td>
                <button class="small-btn" data-toggle-paid="${type}" data-id="${esc(r.id)}">${r.paid?'Marcar pendiente':'Marcar pagada'}</button>
                <button class="danger-btn small-btn" data-delete="${type}" data-id="${esc(r.id)}">Borrar</button>
              </td>`}
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  `;
}

